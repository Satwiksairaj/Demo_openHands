# ─────────────────────────────────────────────────────────────────────────────
# AI Developer Agent — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_MODEL=openai/gpt-4o
LLM_API_KEY=sk-proj-...your-openai-key...
LLM_BASE_URL=https://api.openai.com/v1

# ─── OpenHands ────────────────────────────────────────────────────────────────
OPENHANDS_AGENT=CodeActAgent
OPENHANDS_MAX_ITERATIONS=15
OPENHANDS_CONFIRMATION_MODE=false

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-workspace.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=...your-jira-api-token...

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...your-github-pat...
GITHUB_REPO_URL=https://github.com/your-org/your-repo.git
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_BASE_BRANCH=main

# ─── Agent Behavior ───────────────────────────────────────────────────────────
USE_OPENHANDS=true
TEST_TIMEOUT=300
MAX_RETRIES=3
LOG_LEVEL=INFO
WORKSPACE_BASE=D:/autonomous-dev-agent/workspace
